{
  "name": "trmnl-runescape",
  "version": "1.0.0",
  "description": "TRMNL Recipe helper for RuneScape HiScores.",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "src/worker.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "lint": "oxlint . src/**/*",
    "fmt": "oxfmt --write . src/**/*",
    "fmt:check": "oxfmt --check . src/**/*",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "prune": "knip"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@types/node": "^25.9.4",
    "knip": "^6.17.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  },
  "dependenciesMeta": {
    "esbuild": {
      "built": true
    },
    "sharp": {
      "built": true
    },
    "workerd": {
      "built": true
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.17.0"
}
